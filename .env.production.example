# =============================================================================
# Influencer Manager — Production Environment Variables
# =============================================================================
# Copy this file and set real values for your deployment.
# Railway will set PORT automatically — do not set it manually.

# --- Node ---
NODE_ENV=production

# --- Database (Railway Postgres) ---
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# --- Redis (Railway Redis) ---
# Railway provides this automatically when you add a Redis plugin
# Set to empty or omit if not using Redis/job workers
REDIS_URL=redis://default:password@host:6379

# --- API Configuration ---
# PORT is set automatically by Railway — do not override
# API_HOST=0.0.0.0  (default, no need to set)
API_BASE_PATH=api

# --- Authentication ---
# Must be at least 24 characters in production
JWT_SECRET=your-secure-random-secret-at-least-24-chars
JWT_EXPIRES_IN=1h

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://admin.devomob.com,https://app.devomob.com

# --- Job Workers ---
# Set to true on the worker service, false on the API service
ENABLE_JOB_WORKERS=false

# --- Redis Health Check ---
# Disable if Redis is not provisioned
REDIS_HEALTHCHECK_ENABLED=true

# --- Frontend Build Variables (set on frontend services only) ---
# VITE_API_URL=https://api.devomob.com

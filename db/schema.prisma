generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  active
  inactive

  @@map("organization_status")
}

enum UserRole {
  organization_admin
  campaign_manager
  campaign_editor
  analyst
  viewer
  influencer

  @@map("user_role")
}

enum UserStatus {
  invited
  active
  suspended

  @@map("user_status")
}

enum ClientStatus {
  active
  inactive
  archived

  @@map("client_status")
}

enum CompanyStatus {
  active
  inactive
  archived

  @@map("company_status")
}

enum CampaignStatus {
  draft
  planned
  active
  paused
  completed
  archived

  @@map("campaign_status")
}

enum MissionStatus {
  planned
  active
  completed

  @@map("mission_status")
}

enum ActionStatus {
  draft
  scheduled
  active
  awaiting_submission
  under_review
  completed

  @@map("action_status")
}

enum SocialPlatform {
  instagram
  tiktok
  youtube
  facebook
  x
  linkedin
  threads
  other

  @@map("social_platform")
}

enum ContentFormat {
  in_feed_post
  carousel
  reel
  story
  short_video
  long_form_video
  live_stream
  other

  @@map("content_format")
}

enum InfluencerStatus {
  active
  inactive
  archived

  @@map("influencer_status")
}

enum AssignmentStatus {
  invited
  assigned
  accepted
  in_progress
  submitted
  revision
  approved
  rejected
  completed
  completed_by_cascade
  declined

  @@map("assignment_status")
}

enum DeliverableStatus {
  pending
  submitted
  approved
  rejected

  @@map("deliverable_status")
}

enum DeliverableType {
  draft_content
  final_asset
  caption_copy
  story_frame
  post_link
  other

  @@map("deliverable_type")
}

enum PostMediaType {
  image
  video
  carousel
  story
  short_video
  live_stream
  text
  other

  @@map("post_media_type")
}

enum AssetSourceType {
  upload
  external_link

  @@map("asset_source_type")
}

enum AssetCategory {
  logo
  brand_guidelines
  product_photo
  video_broll
  copy_caption
  hashtag_list
  mood_board
  template
  font
  color_palette
  other

  @@map("asset_category")
}

enum AuditChangedByType {
  user
  influencer
  system

  @@map("audit_changed_by_type")
}

enum MessageTemplateCategory {
  outreach
  assignment_notification
  reminder
  follow_up
  completion
  custom

  @@map("message_template_category")
}

enum ConversationEntityType {
  campaign
  mission
  action
  assignment

  @@map("conversation_entity_type")
}

enum MessageSenderType {
  user
  influencer
  system

  @@map("message_sender_type")
}

enum NotificationType {
  new_message
  assignment_update
  reminder
  system

  @@map("notification_type")
}

enum NotificationRecipientType {
  user
  influencer

  @@map("notification_recipient_type")
}

enum ConversationParticipantStatus {
  active
  archived
  snoozed

  @@map("conversation_participant_status")
}

enum NotificationPreference {
  all_messages
  replies_only
  none

  @@map("notification_preference")
}

enum ImportLogStatus {
  queued
  running
  completed
  failed

  @@map("import_log_status")
}

model Organization {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  slug                  String                @unique
  status                OrganizationStatus    @default(active)
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @updatedAt @db.Timestamptz(6)
  users                 User[]
  clients               Client[]
  companies             Company[]
  campaigns             Campaign[]
  missions              Mission[]
  actions               Action[]
  influencers           Influencer[]
  action_assignments    ActionAssignment[]
  deliverables          Deliverable[]
  posts                 Post[]
  performance_snapshots PerformanceSnapshot[]
  influencer_ratings    InfluencerRating[]
  influencer_notes      InfluencerNote[]
  influencer_clients    InfluencerClient[]
  audit_logs            AuditLog[]
  import_logs           ImportLog[]
  post_performance_summaries PostPerformanceSummary[]
  action_performance_summaries ActionPerformanceSummary[]
  mission_performance_summaries MissionPerformanceSummary[]
  campaign_performance_summaries CampaignPerformanceSummary[]
  influencer_performance_summaries InfluencerPerformanceSummary[]
  message_templates     MessageTemplate[]
  conversations         Conversation[]
  notifications         Notification[]
  campaign_assets       CampaignAsset[]

  @@map("organizations")
}

model User {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String           @db.Uuid
  influencer_id      String?          @db.Uuid
  full_name          String
  email              String           @unique
  password_hash      String?
  role               UserRole
  status                  UserStatus             @default(invited)
  notification_preference NotificationPreference @default(replies_only)
  created_at              DateTime               @default(now()) @db.Timestamptz(6)
  updated_at              DateTime               @updatedAt @db.Timestamptz(6)
  organization            Organization           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  influencer         Influencer?      @relation("influencer_users", fields: [organization_id, influencer_id], references: [organization_id, id], onDelete: Restrict)
  influencer_ratings InfluencerRating[] @relation("user_ratings")
  influencer_notes   InfluencerNote[] @relation("user_notes")
  submitted_deliverables Deliverable[] @relation("user_submitted_deliverables")
  created_templates     MessageTemplate[] @relation("user_created_templates")
  created_conversations Conversation[] @relation("user_created_conversations")
  conversation_participations ConversationParticipant[] @relation("user_participations")
  sent_messages         Message[] @relation("user_sent_messages")
  uploaded_assets       CampaignAsset[] @relation("user_uploaded_assets")

  @@unique([organization_id, id])
  @@unique([organization_id, influencer_id])
  @@index([organization_id])
  @@map("users")
}

model Client {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String         @db.Uuid
  name                  String
  industry              String?
  primary_contact_first_name String?
  primary_contact_name       String?
  primary_contact_email      String?
  primary_contact_phone      String?
  status                ClientStatus   @default(active)
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @updatedAt @db.Timestamptz(6)
  organization          Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  companies             Company[]      @relation("client_companies")
  influencer_clients    InfluencerClient[] @relation("client_influencer_clients")
  campaign_assets       CampaignAsset[]    @relation("client_campaign_assets")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, name])
  @@map("clients")
}

model Company {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  client_id       String       @db.Uuid
  name                   String
  description            String?
  contact_first_name     String?
  contact_last_name      String?
  contact_email          String?
  contact_phone          String?
  priority_instagram     Int           @default(0)
  priority_tiktok        Int           @default(0)
  priority_youtube       Int           @default(0)
  priority_facebook      Int           @default(0)
  priority_x             Int           @default(0)
  priority_linkedin      Int           @default(0)
  priority_threads       Int           @default(0)
  priority_regions          Json          @default("{}")
  priorities_updated_at     DateTime?     @db.Timestamptz(6)
  priorities_updated_by     String?
  status                    CompanyStatus @default(active)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @updatedAt @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  client          Client       @relation("client_companies", fields: [organization_id, client_id], references: [organization_id, id], onDelete: Cascade)
  campaigns       Campaign[]   @relation("company_campaigns")
  campaign_assets CampaignAsset[] @relation("company_campaign_assets")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, client_id])
  @@map("companies")
}

model Campaign {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String            @db.Uuid
  company_id         String            @db.Uuid
  name               String
  description        String?
  campaign_type      String
  status             CampaignStatus    @default(draft)
  version            Int               @default(1)
  start_date         DateTime?         @db.Date
  end_date           DateTime?         @db.Date
  budget             Decimal?          @db.Decimal(12, 2)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @updatedAt @db.Timestamptz(6)
  organization       Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  company            Company           @relation("company_campaigns", fields: [organization_id, company_id], references: [organization_id, id], onDelete: Cascade)
  missions           Mission[]         @relation("campaign_missions")
  influencer_ratings InfluencerRating[] @relation("campaign_ratings")
  campaign_assets   CampaignAsset[]    @relation("campaign_assets")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, company_id])
  @@index([organization_id, status])
  @@map("campaigns")
}

model Mission {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String         @db.Uuid
  campaign_id     String         @db.Uuid
  name            String
  description     String?
  sequence_order  Int
  status            MissionStatus  @default(planned)
  start_date        DateTime?      @db.Date
  end_date          DateTime?      @db.Date
  auto_completed    Boolean        @default(false)
  auto_completed_at DateTime?      @db.Timestamptz(6)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @updatedAt @db.Timestamptz(6)
  organization      Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  campaign          Campaign       @relation("campaign_missions", fields: [organization_id, campaign_id], references: [organization_id, id], onDelete: Cascade)
  actions           Action[]       @relation("mission_actions")

  @@unique([organization_id, id])
  @@unique([campaign_id, sequence_order])
  @@index([organization_id])
  @@index([organization_id, campaign_id])
  @@map("missions")
}

model Action {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String            @db.Uuid
  mission_id            String            @db.Uuid
  title                 String
  platform              SocialPlatform
  instructions          String?
  content_format        ContentFormat
  required_deliverables Int               @default(1)
  approval_required     Boolean           @default(true)
  start_window          DateTime?         @db.Timestamptz(6)
  end_window            DateTime?         @db.Timestamptz(6)
  required_platforms    String[]          @default([])
  status                ActionStatus      @default(draft)
  auto_completed        Boolean           @default(false)
  auto_completed_at     DateTime?         @db.Timestamptz(6)
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @updatedAt @db.Timestamptz(6)
  organization          Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  mission               Mission           @relation("mission_actions", fields: [organization_id, mission_id], references: [organization_id, id], onDelete: Cascade)
  action_assignments    ActionAssignment[] @relation("action_assignments")
  asset_links           CampaignAssetAction[] @relation("action_asset_links")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, mission_id])
  @@index([organization_id, status])
  @@map("actions")
}

model Influencer {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String              @db.Uuid
  name                 String
  email                String?
  primary_platform     SocialPlatform
  location             String?
  mailing_address      String?
  city                 String?
  state                String?
  zip                  String?
  phone                String?
  url_instagram        String?
  url_tiktok           String?
  url_facebook         String?
  url_youtube          String?
  url_linkedin         String?
  url_x                String?
  url_threads          String?
  audience_description String?
  status               InfluencerStatus    @default(active)
  created_at           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime            @updatedAt @db.Timestamptz(6)
  organization         Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users                User[]              @relation("influencer_users")
  action_assignments   ActionAssignment[]  @relation("influencer_assignments")
  influencer_ratings   InfluencerRating[]  @relation("influencer_ratings")
  influencer_notes     InfluencerNote[]    @relation("influencer_notes")
  influencer_clients   InfluencerClient[]  @relation("influencer_influencer_clients")
  conversation_participations ConversationParticipant[] @relation("influencer_participations")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, primary_platform])
  @@map("influencers")
}

model ActionAssignment {
  id                           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id              String            @db.Uuid
  action_id                    String            @db.Uuid
  influencer_id                String            @db.Uuid
  assignment_status            AssignmentStatus  @default(invited)
  cascade_reason               String?
  invited_at                   DateTime?         @db.Timestamptz(6)
  accepted_at                  DateTime?         @db.Timestamptz(6)
  submitted_at                 DateTime?         @db.Timestamptz(6)
  completed_at                 DateTime?         @db.Timestamptz(6)
  revision_count               Int               @default(0)
  revision_reason              String?
  assigned_at                  DateTime          @default(now()) @db.Timestamptz(6)
  due_date                     DateTime?         @db.Timestamptz(6)
  completion_date              DateTime?         @db.Timestamptz(6)
  submission_url               String?
  published_at                 DateTime?         @db.Timestamptz(6)
  total_views                  Int               @default(0)
  total_comments               Int               @default(0)
  total_shares                 Int               @default(0)
  metrics_updated_at           DateTime?         @db.Timestamptz(6)
  deliverable_count_expected   Int               @default(1)
  deliverable_count_submitted  Int               @default(0)
  created_at                   DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime          @updatedAt @db.Timestamptz(6)
  organization                 Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  action                       Action            @relation("action_assignments", fields: [organization_id, action_id], references: [organization_id, id], onDelete: Cascade)
  influencer                   Influencer        @relation("influencer_assignments", fields: [organization_id, influencer_id], references: [organization_id, id], onDelete: Cascade)
  deliverables                 Deliverable[]     @relation("assignment_deliverables")
  influencer_ratings           InfluencerRating[] @relation("assignment_ratings")

  @@unique([organization_id, id])
  @@unique([action_id, influencer_id])
  @@index([organization_id])
  @@index([organization_id, action_id])
  @@index([organization_id, influencer_id])
  @@index([organization_id, assignment_status])
  @@index([organization_id, due_date])
  @@map("action_assignments")
}

model Deliverable {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String            @db.Uuid
  action_assignment_id String            @db.Uuid
  deliverable_type     DeliverableType
  description          String?
  status               DeliverableStatus @default(pending)
  submission_url       String?
  submission_metadata_json Json?
  rejection_reason     String?
  submitted_at         DateTime?         @db.Timestamptz(6)
  approved_at          DateTime?         @db.Timestamptz(6)
  submitted_by_user_id String?           @db.Uuid
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime          @updatedAt @db.Timestamptz(6)
  organization         Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  action_assignment    ActionAssignment  @relation("assignment_deliverables", fields: [organization_id, action_assignment_id], references: [organization_id, id], onDelete: Cascade)
  submitted_by_user    User?             @relation("user_submitted_deliverables", fields: [organization_id, submitted_by_user_id], references: [organization_id, id], onDelete: Restrict)
  posts                Post[]            @relation("deliverable_posts")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, action_assignment_id])
  @@index([organization_id, submitted_by_user_id])
  @@index([organization_id, status])
  @@map("deliverables")
}

model Post {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String              @db.Uuid
  deliverable_id  String              @db.Uuid
  platform        SocialPlatform
  external_post_id String?
  post_url        String
  caption         String?
  media_type      PostMediaType
  posted_at       DateTime?           @db.Timestamptz(6)
  created_at      DateTime            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime            @updatedAt @db.Timestamptz(6)
  organization    Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  deliverable     Deliverable         @relation("deliverable_posts", fields: [organization_id, deliverable_id], references: [organization_id, id], onDelete: Cascade)
  performance_snapshots PerformanceSnapshot[] @relation("post_performance_snapshots")
  import_logs      ImportLog[]         @relation("post_import_logs")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, deliverable_id])
  @@index([organization_id, platform])
  @@map("posts")
}

model PerformanceSnapshot {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String         @db.Uuid
  post_id         String         @db.Uuid
  captured_at     DateTime       @db.Timestamptz(6)
  impressions     Int            @default(0)
  reach           Int            @default(0)
  views           Int            @default(0)
  video_views     Int            @default(0)
  likes           Int            @default(0)
  comments        Int            @default(0)
  shares          Int            @default(0)
  saves           Int            @default(0)
  clicks          Int            @default(0)
  conversions     Int            @default(0)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @updatedAt @db.Timestamptz(6)
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  post            Post           @relation("post_performance_snapshots", fields: [organization_id, post_id], references: [organization_id, id], onDelete: Cascade)

  @@unique([organization_id, id])
  @@unique([post_id, captured_at])
  @@index([organization_id])
  @@index([post_id, captured_at])
  @@index([organization_id, post_id, captured_at])
  @@map("performance_snapshots")
}

model InfluencerRating {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id         String            @db.Uuid
  influencer_id           String            @db.Uuid
  campaign_id             String            @db.Uuid
  action_assignment_id    String?           @db.Uuid
  rater_user_id           String            @db.Uuid
  content_quality_score   Int?
  reliability_score       Int?
  audience_fit_score      Int?
  communication_score     Int?
  brand_safety_score      Int?
  overall_score           Decimal?          @db.Decimal(3, 2)
  visual_quality_score    Int?
  visual_quality_note     String?
  script_quality_score    Int?
  script_quality_note     String?
  overall_quality_score   Int?
  overall_quality_note    String?
  notes                   String?
  created_at              DateTime          @default(now()) @db.Timestamptz(6)
  updated_at              DateTime          @updatedAt @db.Timestamptz(6)
  organization            Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  influencer              Influencer        @relation("influencer_ratings", fields: [organization_id, influencer_id], references: [organization_id, id], onDelete: Cascade)
  campaign                Campaign          @relation("campaign_ratings", fields: [organization_id, campaign_id], references: [organization_id, id], onDelete: Cascade)
  action_assignment       ActionAssignment? @relation("assignment_ratings", fields: [organization_id, action_assignment_id], references: [organization_id, id], onDelete: SetNull)
  rater_user              User              @relation("user_ratings", fields: [organization_id, rater_user_id], references: [organization_id, id], onDelete: Restrict)

  @@unique([organization_id, id])
  @@unique([campaign_id, influencer_id, action_assignment_id, rater_user_id])
  @@index([organization_id])
  @@index([organization_id, campaign_id])
  @@index([organization_id, influencer_id])
  @@index([organization_id, action_assignment_id])
  @@map("influencer_ratings")
}

model InfluencerNote {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  influencer_id   String       @db.Uuid
  author_user_id  String       @db.Uuid
  note_text       String
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @updatedAt @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  influencer      Influencer   @relation("influencer_notes", fields: [organization_id, influencer_id], references: [organization_id, id], onDelete: Cascade)
  author_user     User         @relation("user_notes", fields: [organization_id, author_user_id], references: [organization_id, id], onDelete: Restrict)

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, influencer_id])
  @@map("influencer_notes")
}

model InfluencerClient {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  influencer_id   String       @db.Uuid
  client_id       String       @db.Uuid
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  influencer      Influencer   @relation("influencer_influencer_clients", fields: [organization_id, influencer_id], references: [organization_id, id], onDelete: Cascade)
  client          Client       @relation("client_influencer_clients", fields: [organization_id, client_id], references: [organization_id, id], onDelete: Cascade)

  @@unique([influencer_id, client_id])
  @@index([organization_id])
  @@index([organization_id, influencer_id])
  @@index([organization_id, client_id])
  @@map("influencer_clients")
}

model AuditLog {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id  String             @db.Uuid
  entity_type      String
  entity_id        String             @db.Uuid
  parent_entity_type String?
  parent_entity_id String?            @db.Uuid
  event_type       String
  previous_value   Json?
  new_value        Json?
  changed_by_type  AuditChangedByType
  changed_by_id    String?            @db.Uuid
  reason           String?
  metadata_json    Json?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @updatedAt @db.Timestamptz(6)
  organization     Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, entity_type, entity_id])
  @@index([organization_id, parent_entity_type, parent_entity_id])
  @@map("audit_logs")
}

model ImportLog {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String          @db.Uuid
  post_id           String          @db.Uuid
  platform          SocialPlatform
  status            ImportLogStatus @default(queued)
  requested_at      DateTime        @default(now()) @db.Timestamptz(6)
  completed_at      DateTime?       @db.Timestamptz(6)
  error_message     String?
  raw_metadata_json Json?
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @updatedAt @db.Timestamptz(6)
  organization      Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  post              Post            @relation("post_import_logs", fields: [organization_id, post_id], references: [organization_id, id], onDelete: Cascade)

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, post_id])
  @@index([organization_id, platform, status])
  @@map("import_logs")
}


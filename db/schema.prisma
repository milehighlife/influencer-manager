// ---------------------------------------------------------------------------
// Messaging & Outreach
// ---------------------------------------------------------------------------

model MessageTemplate {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String                  @db.Uuid
  name            String
  subject         String
  body            String
  category        MessageTemplateCategory @default(custom)
  is_default      Boolean                 @default(false)
  created_by_id   String?                 @db.Uuid
  created_at      DateTime                @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                @updatedAt @db.Timestamptz(6)
  organization    Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_by      User?                   @relation("user_created_templates", fields: [organization_id, created_by_id], references: [organization_id, id], onDelete: SetNull)
  messages        Message[]               @relation("template_messages")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, category])
  @@map("message_templates")
}

model Conversation {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String                  @db.Uuid
  subject             String
  related_entity_type  ConversationEntityType?
  related_entity_id    String?                 @db.Uuid
  outreach_batch_id    String?                 @db.Uuid
  outreach_template_name String?
  created_by_id        String?                 @db.Uuid
  created_at           DateTime                @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                @updatedAt @db.Timestamptz(6)
  organization        Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_by          User?                   @relation("user_created_conversations", fields: [organization_id, created_by_id], references: [organization_id, id], onDelete: SetNull)
  participants        ConversationParticipant[] @relation("conversation_participants")
  messages            Message[]               @relation("conversation_messages")

  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([organization_id, related_entity_type, related_entity_id])
  @@index([organization_id, outreach_batch_id])
  @@map("conversations")
}

model ConversationParticipant {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String       @db.Uuid
  user_id         String?      @db.Uuid
  influencer_id   String?      @db.Uuid
  status          ConversationParticipantStatus @default(active)
  snoozed_until   DateTime?    @db.Timestamptz(6)
  joined_at       DateTime     @default(now()) @db.Timestamptz(6)
  last_read_at    DateTime?    @db.Timestamptz(6)
  conversation    Conversation @relation("conversation_participants", fields: [conversation_id], references: [id], onDelete: Cascade)
  user            User?        @relation("user_participations", fields: [user_id], references: [id], onDelete: Cascade)
  influencer      Influencer?  @relation("influencer_participations", fields: [influencer_id], references: [id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@unique([conversation_id, influencer_id])
  @@index([conversation_id])
  @@index([user_id])
  @@index([influencer_id])
  @@map("conversation_participants")
}

model Message {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String            @db.Uuid
  sender_id       String?           @db.Uuid
  sender_type     MessageSenderType
  body            String
  template_id     String?           @db.Uuid
  sent_via_email  Boolean           @default(false)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @updatedAt @db.Timestamptz(6)
  conversation    Conversation      @relation("conversation_messages", fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User?             @relation("user_sent_messages", fields: [sender_id], references: [id], onDelete: SetNull)
  template        MessageTemplate?  @relation("template_messages", fields: [template_id], references: [id], onDelete: SetNull)
  attachments     MessageAttachment[] @relation("message_attachments")

  @@index([conversation_id])
  @@index([conversation_id, created_at])
  @@index([sender_id])
  @@map("messages")
}

model MessageAttachment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id      String   @db.Uuid
  file_name       String
  file_url        String
  file_type       String?
  file_size_bytes Int?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  message         Message  @relation("message_attachments", fields: [message_id], references: [id], onDelete: Cascade)

  @@index([message_id])
  @@map("message_attachments")
}

model Notification {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String                    @db.Uuid
  recipient_id        String                    @db.Uuid
  recipient_type      NotificationRecipientType
  type                NotificationType
  title               String
  body                String
  related_entity_type String?
  related_entity_id   String?                   @db.Uuid
  read_at             DateTime?                 @db.Timestamptz(6)
  created_at          DateTime                  @default(now()) @db.Timestamptz(6)
  organization        Organization              @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([organization_id, recipient_id, recipient_type])
  @@index([organization_id, recipient_id, read_at])
  @@map("notifications")
}

model AutomatedMessageLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  assignment_id   String   @db.Uuid
  template_type   String
  sent_at         DateTime @default(now()) @db.Timestamptz(6)

  @@unique([assignment_id, template_type])
  @@index([organization_id])
  @@index([assignment_id])
  @@map("automated_message_logs")
}

// ---------------------------------------------------------------------------
// Campaign Media Library
// ---------------------------------------------------------------------------

model CampaignAsset {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  campaign_id     String          @db.Uuid
  client_id       String          @db.Uuid
  company_id      String          @db.Uuid
  name            String
  description     String?
  source_type     AssetSourceType
  file_url        String
  file_name       String?
  file_size_bytes Int?
  mime_type       String?
  thumbnail_url   String?
  category        AssetCategory   @default(other)
  tags            String[]        @default([])
  sort_order      Int             @default(0)
  uploaded_by_id  String?         @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @updatedAt @db.Timestamptz(6)
  organization    Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  campaign        Campaign        @relation("campaign_assets", fields: [campaign_id], references: [id], onDelete: Cascade)
  client          Client          @relation("client_campaign_assets", fields: [client_id], references: [id], onDelete: Cascade)
  company         Company         @relation("company_campaign_assets", fields: [company_id], references: [id], onDelete: Cascade)
  uploaded_by     User?           @relation("user_uploaded_assets", fields: [uploaded_by_id], references: [id], onDelete: SetNull)
  action_links    CampaignAssetAction[] @relation("asset_action_links")

  @@index([organization_id])
  @@index([organization_id, campaign_id])
  @@index([client_id, created_at(sort: Desc)])
  @@index([organization_id, company_id])
  @@index([organization_id, category])
  @@map("campaign_assets")
}

model CampaignAssetAction {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_asset_id String        @db.Uuid
  action_id         String        @db.Uuid
  campaign_asset    CampaignAsset @relation("asset_action_links", fields: [campaign_asset_id], references: [id], onDelete: Cascade)
  action            Action        @relation("action_asset_links", fields: [action_id], references: [id], onDelete: Cascade)

  @@unique([campaign_asset_id, action_id])
  @@index([campaign_asset_id])
  @@index([action_id])
  @@map("campaign_asset_actions")
}
